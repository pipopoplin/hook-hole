{
  "enabled": true,
  "plugin_priority": ["presidio", "spacy", "gliner", "distilbert"],
  "fallback_strategy": "first_available",
  "field": "tool_input.command",
  "min_confidence": 0.7,
  "action": "deny",
  "entity_types": [
    "PERSON", "EMAIL_ADDRESS", "PHONE_NUMBER",
    "US_SSN", "CREDIT_CARD", "IP_ADDRESS"
  ],
  "plugins": {
    "presidio": {
      "enabled": true,
      "languages": ["en"],
      "score_threshold": 0.6
    },
    "gliner": {
      "enabled": true,
      "model": "urchade/gliner_base",
      "labels": ["person", "email", "phone number", "social security number", "credit card", "api key"],
      "threshold": 0.5
    },
    "distilbert": {
      "enabled": true,
      "model": "dslim/distilbert-NER",
      "score_threshold": 0.8
    },
    "spacy": {
      "enabled": true,
      "model": "en_core_web_sm",
      "extra_patterns": true
    }
  }
}
