{
  "plugins": {
    "presidio": {
      "module": "plugins.presidio_plugin",
      "class": "PresidioPlugin",
      "tier": "SubMillisecond",
      "latency": "~0.4ms",
      "description": "Microsoft Presidio — known PII types, max speed",
      "install": "pip install presidio-analyzer"
    },
    "gliner": {
      "module": "plugins.gliner_plugin",
      "class": "GLiNERPlugin",
      "tier": "ZeroShot",
      "latency": "~18ms",
      "description": "GLiNER — zero-shot NER, flexible custom labels (use v2.1+ for Apache 2.0 license)",
      "install": "pip install gliner"
    },
    "distilbert": {
      "module": "plugins.distilbert_plugin",
      "class": "DistilBERTPlugin",
      "tier": "HighAccuracy",
      "latency": "~25ms",
      "description": "DistilBERT / NerGuard — best accuracy NER",
      "install": "pip install transformers torch"
    },
    "spacy": {
      "module": "plugins.spacy_plugin",
      "class": "SpaCyPlugin",
      "tier": "EdgeDevice",
      "latency": "~3ms",
      "description": "spaCy sm + regex — edge/low-resource",
      "install": "pip install spacy && python -m spacy download en_core_web_sm"
    }
  }
}
