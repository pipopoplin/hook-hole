{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/regex_filter.py \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/filter_rules.json",
            "timeout": 10,
            "statusMessage": "Checking command against filter rules..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/llm_filter.py \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/llm_filter_config.json",
            "timeout": 30,
            "statusMessage": "Scanning for sensitive content (NLP)..."
          }
        ]
      }
    ]
  }
}
